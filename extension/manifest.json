{
  "manifest_version": 3,
  "name": "Productivity Tracker",
  "version": "2.0",
  "description": "Track and visualize your web usage with smart insights.",
  "permissions": ["tabs", "storage", "scripting", "notifications", "idle", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}